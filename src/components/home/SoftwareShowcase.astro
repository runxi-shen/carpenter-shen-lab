---
const base = import.meta.env.BASE_URL;

const tools = [
  {
    name: 'CellProfiler',
    description: 'Open-source cell image analysis software used worldwide in drug discovery and genomics research.',
    github: 'https://github.com/CellProfiler/CellProfiler',
    website: 'https://cellprofiler.org',
    tag: 'Flagship',
  },
  {
    name: 'DeepProfiler',
    description: 'Deep learning framework for extracting morphological representations from microscopy images.',
    github: 'https://github.com/cytomining/DeepProfiler',
    tag: 'Deep Learning',
  },
  {
    name: 'PyCytominer',
    description: 'Python package for processing and normalizing high-dimensional morphological profiles.',
    github: 'https://github.com/cytomining/pycytominer',
    tag: 'Data Processing',
  },
  {
    name: 'Copairs',
    description: 'Statistical methods for hit identification in large-scale perturbation screens.',
    github: 'https://github.com/cytomining/copairs',
    tag: 'Statistics',
  },
];
---

<section class="py-28 px-4 sm:px-6 lg:px-8" style="background: var(--section-gradient);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">Open Source</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Software & Tools</h2>
      <p class="mt-4 max-w-2xl mx-auto text-base text-center" style="color: var(--text-secondary);">
        We build and maintain open-source tools that power computational image analysis worldwide.
      </p>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- Tool Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto">
      {tools.map(tool => (
        <div class="card-base group">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-base font-semibold" style="color: var(--text-heading);">
              {tool.name}
            </h3>
            <span class="text-xs font-mono px-2 py-0.5 rounded-full"
                  style="background: color-mix(in srgb, var(--accent-gold) 10%, transparent); color: var(--accent-gold);">
              {tool.tag}
            </span>
          </div>
          <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
            {tool.description}
          </p>
          <div class="flex items-center gap-3">
            <a href={tool.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: var(--accent-gold);">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
            {tool.website && (
              <a href={tool.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: var(--accent-cyan);">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Website
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href={`${base}/software/`}
         class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium text-sm transition-all"
         style="border: 1px solid var(--accent-gold-dim); color: var(--accent-gold);">
        View All Software
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
