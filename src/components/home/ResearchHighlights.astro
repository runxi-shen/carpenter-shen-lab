---
import cellprofilerIcon from '../../assets/images/icons/cellprofiler.png';
import cellpaintingIcon from '../../assets/images/icons/cellpainting.png';
import vimeoThumbnail from '../../assets/images/icons/vimeo_thumbnail.png';

const base = import.meta.env.BASE_URL;

const highlights = [
  {
    title: 'Image-Based Profiling',
    description: 'Extracting rich, quantitative morphological fingerprints from microscopy images of cells to reveal the effects of chemical and genetic perturbations at scale.',
    icon: null,
    emoji: '🔬',
    accent: 'var(--accent-gold)',
  },
  {
    title: 'CellProfiler',
    description: 'Our flagship open-source software for measuring and analyzing cell images, cited in over 25,000 publications and used worldwide in pharmaceutical and academic research.',
    icon: cellprofilerIcon.src,
    emoji: null,
    accent: 'var(--accent-cyan)',
  },
  {
    title: 'Cell Painting',
    description: 'A high-throughput morphological profiling assay using fluorescent dyes to create comprehensive cellular fingerprints for drug discovery and toxicology.',
    icon: cellpaintingIcon.src,
    emoji: null,
    accent: 'var(--accent-gold)',
  },
];
---

<section class="py-28 px-4 sm:px-6 lg:px-8" style="background: var(--bg-content);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">What We Do</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Research</h2>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- Videos -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <!-- Vimeo: Lab overview (thumbnail placeholder — TODO: replace with iframe embed once domain is whitelisted in Vimeo privacy settings, video ID: 514015653) -->
      <a href="https://vimeo.com/514015653" target="_blank" rel="noopener noreferrer" class="rounded-xl overflow-hidden shadow-lg block group" style="background: var(--bg-card);">
        <div class="relative w-full">
          <img src={vimeoThumbnail.src} alt="Lab overview video — click to watch on Vimeo" class="w-full h-auto block" />
          <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
            <svg class="w-16 h-16 text-white opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </a>
      <!-- YouTube: Research talk -->
      <div class="rounded-xl overflow-hidden shadow-lg h-full" style="background: var(--bg-card);">
        <iframe
          src="https://www.youtube.com/embed/KDQFUmDJ3nY?start=12"
          class="w-full h-full"
          style="min-height: 300px;"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          title="Research Talk"
        ></iframe>
      </div>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {highlights.map((item, i) => (
        <div class="card-base group relative overflow-hidden p-9" style={`animation-delay: ${i * 0.15}s`}>
          <!-- Top accent line -->
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-xl" style={`background: ${item.accent};`}></div>

          {item.icon ? (
            <img src={item.icon} alt={item.title} class="w-14 h-14 mb-6 rounded-lg object-contain" />
          ) : (
            <div class="text-5xl mb-6">{item.emoji}</div>
          )}
          <h3 class="text-2xl font-semibold mb-4" style="color: var(--text-heading);">
            {item.title}
          </h3>
          <p class="text-base leading-relaxed mb-6" style="color: var(--text-secondary);">
            {item.description}
          </p>

          <!-- Learn more link -->
          <a href={`${base}/research/`}
             class="inline-flex items-center gap-2 text-base font-semibold transition-colors"
             style={`color: ${item.accent};`}>
            Learn more
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
