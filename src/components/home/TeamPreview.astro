---
import annePhoto from '../../assets/images/team/Anne_Carpenter_resized.png';
import runxiPhoto from '../../assets/images/team/Runxi_Shen_resized.jpg';

const base = import.meta.env.BASE_URL;

const teamMembers = [
  {
    name: 'Anne E. Carpenter',
    role: 'Principal Investigator',
    title: 'Professor',
    photo: annePhoto.src,
    accentColor: 'var(--accent-gold)',
    accentDim: 'var(--accent-gold-dim)',
    bio: 'Leading the JUMP, OASIS, and VISTA consortia and the Cell2Cure Engine at Purdue University, coordinating large-scale collaborative research efforts across institutions and industry partners to harness image-based profiling for accelerating drug discovery.',
  },
  {
    name: 'Runxi Shen',
    role: 'Co-Principal Investigator',
    title: 'Research Assistant Professor',
    photo: runxiPhoto.src,
    accentColor: 'var(--accent-cyan)',
    accentDim: 'var(--accent-cyan-dim)',
    bio: 'Developing computational methods for extracting meaningful features from cell images and applying them to biological discoveries, spanning representation learning, deep learning, and large-scale morphological profiling.',
  },
];
---

<section class="py-28 px-4 sm:px-6 lg:px-8" style="background: var(--section-gradient);">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label">Our Team</span>
      <h2 class="mt-4" style="color: var(--text-heading);">Meet the Researchers</h2>
      <p class="mt-4 max-w-3xl mx-auto text-lg text-center" style="color: var(--text-secondary);">
        Our lab combines expertise in computational biology, machine learning, and cell biology
        to push the boundaries of image-based drug discovery.
      </p>
      <div class="section-divider mt-8 w-24 mx-auto"></div>
    </div>

    <!-- PI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-12">
      {teamMembers.map(member => (
        <div class="card-base text-center group p-8">
          <!-- Photo -->
          <img
            src={member.photo}
            alt={member.name}
            class="w-36 h-36 rounded-full mx-auto mb-6 object-cover"
            style={`border: 3px solid ${member.accentDim};`}
          />

          <h3 class="text-2xl font-semibold mb-2" style="color: var(--text-heading);">{member.name}</h3>

          <!-- Role badge -->
          <span class="inline-block text-sm font-semibold font-mono px-4 py-1.5 rounded-full mt-1 mb-2"
                style={`background: color-mix(in srgb, ${member.accentColor} 12%, transparent); color: ${member.accentColor};`}>
            {member.role}
          </span>

          <p class="text-base font-medium font-mono mt-1 mb-5 text-center" style="color: var(--text-secondary); font-size: 0.95rem;">
            {member.title}
          </p>

          <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
            {member.bio}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a href={`${base}/people/`}
         class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold text-sm transition-all hover:shadow-gold-glow"
         style="border: 1px solid var(--accent-gold-dim); color: var(--accent-gold);">
        Meet the Full Team
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
