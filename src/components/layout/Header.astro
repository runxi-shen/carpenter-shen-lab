---
import ThemeSwitcher from './ThemeSwitcher.astro';

const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Home', href: `${base}/` },
  { label: 'People', href: `${base}/people/` },
  { label: 'Research', href: `${base}/research/` },
  { label: 'Papers', href: `${base}/papers/` },
  { label: 'Software', href: `${base}/software/` },
  { label: 'Positions', href: `${base}/positions/` },
  { label: 'Blog', href: `${base}/blog/` },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b"
  style="background: var(--nav-bg); border-color: var(--border-subtle);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Lab Name -->
      <a href={base} class="flex items-center gap-3 group">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm"
             style="background: var(--accent-gold); color: var(--text-on-accent);">
          CS
        </div>
        <div class="hidden sm:flex items-baseline gap-2">
          <span class="font-semibold text-sm" style="color: var(--nav-text);">
            Carpenter-Shen Lab
          </span>
          <span class="text-xs" style="color: var(--text-secondary);">
            Purdue University
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-medium rounded-lg transition-colors hover:bg-white/5"
            style="color: var(--nav-text);"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Theme Switcher + Mobile Menu -->
      <div class="flex items-center gap-3">
        <div class="hidden sm:block">
          <ThemeSwitcher />
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg"
          style="color: var(--nav-text);"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t"
    style="background: var(--nav-bg); border-color: var(--border-subtle);"
  >
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-3 py-2 text-sm font-medium rounded-lg transition-colors"
          style="color: var(--nav-text);"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 sm:hidden">
        <ThemeSwitcher />
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && !btn.dataset.listenerAttached) {
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    }
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
